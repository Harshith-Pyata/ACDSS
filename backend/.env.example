DATABASE_URL=sqlite:///./acdss.db
FRONTEND_ORIGIN=http://localhost:5173

# LLM / AI keys (keep these secret — never commit real values!)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Chroma DB paths (leave blank to use auto-detected relative paths)
# CHROMA_DIAGNOSIS_DB_PATH=
# CHROMA_TREATMENT_DB_PATH=

# Tesseract (Windows only — on Linux it uses system PATH)
# TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe
